---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import DashboardSidebar from "../components/DashboardSidebar";
import ProductCard from "../components/ProductCard";
import { products } from "../data/products";
import { Package, Truck, CheckCircle } from "lucide-react";

// Recommended products for dashboard
const recommended = products.slice(0, 4);
---

<Layout title="Dashboard - Cat Market">
    <Navbar client:load />

    <main className="min-h-screen pt-[120px] md:pt-[140px] bg-gray-50 pb-20">
        <div className="container mx-auto px-4">
            {/* Breadcrumb / Title */}
            <div className="mb-6">
                <h1 className="text-2xl font-bold text-gray-800">Akun Saya</h1>
            </div>

            <div className="flex flex-col md:flex-row gap-6">
                {/* Sidebar */}
                <div className="w-full md:w-1/4">
                    <DashboardSidebar client:load />
                </div>

                {/* Main Content */}
                <div className="w-full md:w-3/4 space-y-6">
                    {/* Order Status Cards */}
                    <div
                        className="bg-white rounded-xl shadow-sm border border-gray-100 p-6"
                    >
                        <h2 className="text-lg font-bold text-gray-800 mb-4">
                            Status Pesanan
                        </h2>
                        <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div
                                className="bg-blue-50 p-4 rounded-lg flex items-center gap-4 border border-blue-100"
                            >
                                <div
                                    className="p-3 bg-blue-100 rounded-full text-blue-600"
                                >
                                    <Package className="w-6 h-6" />
                                </div>
                                <div>
                                    <span
                                        className="block text-2xl font-bold text-blue-700"
                                        >2</span
                                    >
                                    <span className="text-sm text-blue-600"
                                        >Belum Bayar</span
                                    >
                                </div>
                            </div>
                            <div
                                className="bg-yellow-50 p-4 rounded-lg flex items-center gap-4 border border-yellow-100"
                            >
                                <div
                                    className="p-3 bg-yellow-100 rounded-full text-yellow-600"
                                >
                                    <Truck className="w-6 h-6" />
                                </div>
                                <div>
                                    <span
                                        className="block text-2xl font-bold text-yellow-700"
                                        >1</span
                                    >
                                    <span className="text-sm text-yellow-600"
                                        >Dikirim</span
                                    >
                                </div>
                            </div>
                            <div
                                className="bg-green-50 p-4 rounded-lg flex items-center gap-4 border border-green-100"
                            >
                                <div
                                    className="p-3 bg-green-100 rounded-full text-green-600"
                                >
                                    <CheckCircle className="w-6 h-6" />
                                </div>
                                <div>
                                    <span
                                        className="block text-2xl font-bold text-green-700"
                                        >12</span
                                    >
                                    <span className="text-sm text-green-600"
                                        >Selesai</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>

                    {/* Recent Transaction */}
                    <div
                        className="bg-white rounded-xl shadow-sm border border-gray-100 p-6"
                    >
                        <div className="flex justify-between items-center mb-4">
                            <h2 className="text-lg font-bold text-gray-800">
                                Transaksi Terakhir
                            </h2>
                            <a
                                href="#"
                                className="text-sm text-primary font-medium hover:underline"
                                >Lihat Semua</a
                            >
                        </div>

                        <div
                            className="border border-gray-200 rounded-lg overflow-hidden"
                        >
                            <div
                                className="p-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center"
                            >
                                <span className="text-sm text-gray-600"
                                    >INV/20260211/MPL/123456</span
                                >
                                <span
                                    className="text-xs font-bold bg-green-100 text-green-700 px-2 py-1 rounded"
                                    >Selesai</span
                                >
                            </div>
                            <div className="p-4 flex gap-4">
                                <img
                                    src={products[0].image}
                                    alt={products[0].name}
                                    className="w-16 h-16 object-cover rounded-md border border-gray-100"
                                />
                                <div>
                                    <h4 className="font-medium text-gray-800">
                                        {products[0].name}
                                    </h4>
                                    <p className="text-sm text-gray-500">
                                        1 x Rp {
                                            products[0].price.toLocaleString(
                                                "id-ID",
                                            )
                                        }
                                    </p>
                                </div>
                                <div
                                    className="ml-auto flex flex-col items-end justify-center"
                                >
                                    <span className="text-gray-500 text-xs mb-1"
                                        >Total Belanja</span
                                    >
                                    <span className="font-bold text-gray-800"
                                        >Rp {
                                            products[0].price.toLocaleString(
                                                "id-ID",
                                            )
                                        }</span
                                    >
                                </div>
                            </div>
                            <div className="p-3 bg-gray-50 text-right">
                                <button
                                    className="bg-primary text-white text-sm px-4 py-2 rounded-lg font-medium hover:bg-orange-600 transition-colors"
                                    >Beli Lagi</button
                                >
                            </div>
                        </div>
                    </div>

                    {/* Recommended */}
                    <div
                        className="bg-white rounded-xl shadow-sm border border-gray-100 p-6"
                    >
                        <h2 className="text-lg font-bold text-gray-800 mb-4">
                            Rekomendasi Untukmu
                        </h2>
                        <div className="grid grid-cols-2 lg:grid-cols-4 gap-4">
                            {
                                recommended.map((product) => (
                                    <ProductCard
                                        client:idle
                                        key={product.id}
                                        {...product}
                                    />
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>
