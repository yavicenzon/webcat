---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar";
import ProductCard from "../../components/ProductCard";
import db from "../../lib/db";
import type { Product } from "../../data/products";
import {
    Star,
    MapPin,
    ShieldCheck,
    Heart,
    Share2,
    ShoppingCart,
    MessageCircle,
    Store,
} from "lucide-react";

export function getStaticPaths() {
    const productIds = db
        .prepare(
            `
    SELECT id FROM products
`,
        )
        .all() as { id: string | number }[];

    return productIds.map((product) => ({
        params: { id: String(product.id) },
    }));
}

const { id } = Astro.params;

if (!id) {
    return Astro.redirect("/market");
}

// Get user session
const sessionId = Astro.cookies.get("session_id")?.value;
let user = null;
if (sessionId) {
    user = db
        .prepare(
            `
        SELECT u.username, u.email 
        FROM users u 
        JOIN sessions s ON u.id = s.user_id 
        WHERE s.id = ? AND s.expires_at > ?
    `,
        )
        .get(sessionId, new Date().toISOString()) as {
        username: string;
        email: string;
    } | null;
}

const productData = db
    .prepare(
        `
    SELECT * FROM products WHERE id = ?
`,
    )
    .get(id) as any;

if (!productData) {
    return Astro.redirect("/404");
}

const product: Product = {
    ...productData,
    isAd: Boolean(productData.isAd),
    originalPrice: productData.originalPrice || undefined,
    discount: productData.discount || undefined,
};

// Related products
const relatedProducts = (
    db
        .prepare(
            `
    SELECT * FROM products 
    WHERE category = ? AND id != ? 
    LIMIT 4
`,
        )
        .all(product.category, product.id) as any[]
).map((p) => ({
    ...p,
    isAd: Boolean(p.isAd),
    originalPrice: p.originalPrice || undefined,
    discount: p.discount || undefined,
})) as Product[];

const formatPrice = (p: number) => {
    return new Intl.NumberFormat("id-ID", {
        style: "currency",
        currency: "IDR",
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
    }).format(p);
};

// Mock Data
const variants = ["Original", "Salmon", "Tuna", "Chicken"];
const stock = 15;
---

<Layout title={`${product.name} - Cat Market`}>
    <Navbar client:load user={user} />

    <main class="min-h-screen pt-[120px] md:pt-[140px] bg-white pb-20">
        <div class="container mx-auto px-4 max-w-7xl">
            {/* Breadcrumb */}
            <div class="text-sm text-gray-500 mb-6 flex items-center gap-2">
                <a href="/" class="hover:text-primary">Home</a>
                <span>/</span>
                <a href="/market" class="hover:text-primary"
                    >{product.category}</a
                >
                <span>/</span>
                <span class="text-gray-800 font-medium truncate max-w-[200px]"
                    >{product.name}</span
                >
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
                {/* LEFT: Images (Col 4) */}
                <div class="lg:col-span-4">
                    <div class="sticky top-[140px]">
                        <div
                            class="aspect-square rounded-xl overflow-hidden border border-gray-100 mb-4 relative group cursor-zoom-in"
                        >
                            <img
                                src={product.image}
                                alt={product.name}
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                            {
                                product.discount && (
                                    <div class="absolute top-0 left-0 bg-red-100 text-red-600 font-bold px-3 py-1 rounded-br-xl text-sm">
                                        Hemat {product.discount}%
                                    </div>
                                )
                            }
                        </div>
                        <div class="grid grid-cols-5 gap-2">
                            {
                                [1, 2, 3, 4, 5].map((_, i) => (
                                    <div
                                        class={`aspect-square rounded-lg border overflow-hidden cursor-pointer hover:border-primary transition-all ${i === 0 ? "border-primary ring-1 ring-primary" : "border-gray-200"}`}
                                    >
                                        <img
                                            src={product.image}
                                            class="w-full h-full object-cover"
                                        />
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>

                {/* CENTER: Info (Col 5) */}
                <div class="lg:col-span-5">
                    <h1
                        class="text-xl md:text-2xl font-bold text-gray-900 leading-snug mb-3"
                    >
                        {product.name}
                    </h1>

                    <div
                        class="flex items-center gap-4 text-sm text-gray-500 mb-6"
                    >
                        <span class="font-medium text-gray-900"
                            >Terjual <span class="text-gray-500 font-normal"
                                >100+</span
                            ></span
                        >
                        <span class="border-l border-gray-300 h-4"></span>
                        <div class="flex items-center gap-1">
                            <Star
                                className="w-4 h-4 fill-yellow-400 text-yellow-400"
                            />
                            <span class="font-bold text-gray-900"
                                >{product.rating}</span
                            >
                            <span class="text-gray-400">(25 rating)</span>
                        </div>
                        <span class="border-l border-gray-300 h-4"></span>
                        <span class="font-medium text-gray-900"
                            >Diskusi <span class="text-gray-500 font-normal"
                                >(4)</span
                            ></span
                        >
                    </div>

                    <div class="text-3xl font-bold text-gray-900 mb-2">
                        {formatPrice(product.price)}
                    </div>
                    {
                        product.originalPrice && (
                            <div class="flex items-center gap-2 mb-6">
                                <span class="bg-red-100 text-red-600 font-bold text-xs px-1.5 py-0.5 rounded">
                                    {product.discount}%
                                </span>
                                <span class="text-gray-400 line-through text-sm">
                                    {formatPrice(product.originalPrice)}
                                </span>
                            </div>
                        )
                    }

                    <div class="h-px bg-gray-100 my-6"></div>

                    {/* Varian */}
                    <div class="mb-8">
                        <h3 class="font-semibold text-gray-900 mb-3">
                            Pilih Varian: <span
                                class="text-gray-500 font-normal"
                                >Original</span>
                        </h3>
                        <div class="flex flex-wrap gap-3">
                            {
                                variants.map((v, i) => (
                                    <button
                                        class={`px-4 py-2 rounded-lg border text-sm font-medium transition-all ${i === 0 ? "border-primary bg-orange-50 text-primary" : "border-gray-200 text-gray-600 hover:border-gray-300"}`}
                                    >
                                        {v}
                                    </button>
                                ))
                            }
                        </div>
                    </div>

                    <div class="h-px bg-gray-100 my-6"></div>

                    {/* Detail Info */}
                    <div class="mb-8">
                        <h3 class="font-bold text-gray-900 text-lg mb-4">
                            Detail Produk
                        </h3>
                        <div class="prose prose-sm text-gray-600 max-w-none">
                            {
                                productData.description ? (
                                    <p>{productData.description}</p>
                                ) : (
                                    <>
                                        <p>
                                            <strong>{product.name}</strong>{" "}
                                            adalah produk pilihan terbaik untuk
                                            anabul kesayangan Anda.
                                        </p>
                                        <ul class="list-disc pl-4 mt-2 mb-4 space-y-1">
                                            <li>Kualitas premium terjamin</li>
                                            <li>Aman untuk hewan peliharaan</li>
                                            <li>
                                                Dikirim dengan pengemasan aman
                                            </li>
                                        </ul>
                                        <p>
                                            Stok terbatas! Segera checkout
                                            sebelum kehabisan.
                                        </p>
                                    </>
                                )
                            }
                        </div>
                    </div>

                    {/* Shop Info Card */}
                    <div
                        class="flex items-center gap-4 p-4 border border-gray-100 rounded-xl bg-white shadow-sm hover:shadow-md transition-shadow cursor-pointer"
                    >
                        <div
                            class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center border border-gray-200"
                        >
                            <Store className="w-8 h-8 text-gray-400" />
                        </div>
                        <div class="flex-1">
                            <div class="flex items-center gap-1">
                                <h3 class="font-bold text-gray-800 text-lg">
                                    Cat Market Official
                                </h3>
                                <ShieldCheck
                                    className="w-4 h-4 text-primary fill-current"
                                />
                            </div>
                            <div class="flex items-center gap-2 text-sm">
                                <span class="text-green-600 font-semibold"
                                    >• Online</span
                                >
                                <span class="text-gray-300">|</span>
                                <span class="text-gray-500">Jakarta Barat</span>
                            </div>
                        </div>
                        <button
                            class="px-6 py-2 border border-primary text-primary font-bold rounded-lg hover:bg-orange-50 transition-colors text-sm"
                            >Follow</button
                        >
                    </div>
                </div>

                {/* RIGHT: Action Card (Col 3) - Sticky */}
                <div class="lg:col-span-3">
                    <div
                        class="border border-gray-200 rounded-xl p-4 shadow-[0_2px_10px_rgba(0,0,0,0.05)] sticky top-[140px] bg-white"
                    >
                        <h3 class="font-bold text-gray-900 mb-4">
                            Atur jumlah dan catatan
                        </h3>

                        <div class="flex items-start gap-3 mb-4">
                            <div
                                class="w-16 h-16 rounded border border-gray-200 p-1 flex-shrink-0"
                            >
                                <img
                                    src={product.image}
                                    class="w-full h-full object-cover rounded-sm"
                                />
                            </div>
                            <p class="text-sm text-gray-600 line-clamp-2">
                                {product.name} - Original
                            </p>
                        </div>

                        <div class="flex items-center gap-3 mb-2">
                            <div
                                class="flex items-center border border-gray-300 rounded-lg h-9"
                            >
                                <button
                                    class="px-3 h-full hover:bg-gray-50 text-gray-500 rounded-l-lg transition-colors"
                                    >-</button
                                >
                                <input
                                    type="text"
                                    value="1"
                                    class="w-12 h-full text-center text-sm border-x border-gray-300 focus:outline-none text-gray-700 font-medium"
                                    readonly
                                />
                                <button
                                    class="px-3 h-full hover:bg-gray-50 text-primary font-bold rounded-r-lg transition-colors"
                                    >+</button
                                >
                            </div>
                            <span class="text-sm text-gray-500"
                                >Stok Total: <span
                                    class="text-gray-800 font-semibold"
                                    >{stock}</span
                                ></span
                            >
                        </div>
                        <p class="text-xs text-orange-500 mb-6">
                            Max. pembelian 5 pcs
                        </p>

                        <div class="flex justify-between items-center mb-6">
                            <span class="text-gray-500">Subtotal</span>
                            <span class="font-bold text-xl text-gray-900"
                                >{formatPrice(product.price)}</span
                            >
                        </div>

                        <div class="flex flex-col gap-3">
                            <button
                                class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:bg-orange-600 transition-shadow shadow-lg shadow-orange-200 flex items-center justify-center gap-2"
                            >
                                <span class="text-lg">+</span> Keranjang
                            </button>
                            <button
                                class="w-full border border-primary text-primary font-bold py-3 rounded-lg hover:bg-orange-50 transition-colors"
                            >
                                Beli Langsung
                            </button>
                        </div>

                        <div
                            class="flex justify-between mt-6 pt-4 border-t border-gray-100 text-sm font-semibold text-gray-500"
                        >
                            <button
                                class="flex items-center gap-1.5 hover:text-primary transition-colors"
                            >
                                <MessageCircle className="w-4 h-4" /> Chat
                            </button>
                            <button
                                class="flex items-center gap-1.5 hover:text-primary transition-colors"
                            >
                                <Heart className="w-4 h-4" /> Wishlist
                            </button>
                            <button
                                class="flex items-center gap-1.5 hover:text-primary transition-colors"
                            >
                                <Share2 className="w-4 h-4" /> Share
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            {/* Related Products */}
            <div class="mt-16 pt-8 border-t border-gray-100">
                <h3 class="text-2xl font-bold text-gray-900 mb-6">
                    Lainnya di toko ini
                </h3>
                <div
                    class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4"
                >
                    {
                        relatedProducts.length > 0
                            ? relatedProducts.map((p) => (
                                  <ProductCard
                                      client:visible
                                      key={p.id}
                                      {...p}
                                  />
                              ))
                            : [1, 2, 3, 4, 5].map(() => (
                                  <div class="animate-pulse">
                                      <div class="bg-gray-200 aspect-square rounded-xl mb-3" />
                                      <div class="h-4 bg-gray-200 rounded w-3/4 mb-2" />
                                      <div class="h-4 bg-gray-200 rounded w-1/2" />
                                  </div>
                              ))
                    }
                </div>
            </div>
        </div>
    </main>
</Layout>
