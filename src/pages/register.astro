---
import Layout from "../layouts/Layout.astro";
import db from "../lib/db";

let error = "";
let success = "";

if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const username = formData.get("username")?.toString();
        const email = formData.get("email")?.toString();
        const phone = formData.get("phone")?.toString();
        const password = formData.get("password")?.toString();
        const confirmPassword = formData.get("confirmPassword")?.toString();

        if (!username || !email || !phone || !password || !confirmPassword) {
            error = "Harap isi semua kolom.";
        } else if (password !== confirmPassword) {
            error = "Password tidak cocok.";
        } else {
            // Check if user exists
            const existingUser = db
                .prepare(
                    `
                SELECT * FROM users 
                WHERE email = ? OR username = ? OR phone = ?
            `,
                )
                .get(email, username, phone) as any;

            if (existingUser) {
                error = "Username, email, atau nomor telepon sudah terdaftar.";
            } else {
                // Insert user
                const userId = crypto.randomUUID();
                db.prepare(
                    `
                    INSERT INTO users (id, username, email, phone, password)
                    VALUES (?, ?, ?, ?, ?)
                `,
                ).run(userId, username, email, phone, password);

                success = "Pendaftaran berhasil! Silakan login.";
                return Astro.redirect("/login?message=success");
            }
        }
    } catch (e) {
        console.error(e);
        error = "Internal server error.";
    }
}
---

<Layout title="Register - Cat Market">
    <div
        class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-8"
    >
        <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
            <div class="text-center mb-8">
                <h1 class="text-2xl font-bold text-gray-800">Buat Akun Baru</h1>
                <p class="text-gray-500 text-sm mt-2">
                    Daftar sekarang untuk mulai berbelanja
                </p>
            </div>

            {
                error && (
                    <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-6 text-center border border-red-100">
                        {error}
                    </div>
                )
            }
            {
                success && (
                    <div class="bg-green-50 text-green-600 p-3 rounded-lg text-sm mb-6 text-center border border-green-100">
                        {success}
                    </div>
                )
            }

            <form method="POST" class="space-y-4">
                <div>
                    <label
                        for="username"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Username</label
                    >
                    <input
                        type="text"
                        name="username"
                        id="username"
                        required
                        class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                        placeholder="Contoh: user123"
                    />
                </div>

                <div>
                    <label
                        for="email"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Email</label
                    >
                    <input
                        type="email"
                        name="email"
                        id="email"
                        required
                        class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                        placeholder="nama@email.com"
                    />
                </div>

                <div>
                    <label
                        for="phone"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Nomor Telepon</label
                    >
                    <input
                        type="tel"
                        name="phone"
                        id="phone"
                        required
                        class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                        placeholder="08xxxxxxxxxx"
                    />
                </div>

                <div>
                    <label
                        for="password"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Password</label
                    >
                    <input
                        type="password"
                        name="password"
                        id="password"
                        required
                        class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                        placeholder="••••••••"
                    />
                </div>

                <div>
                    <label
                        for="confirmPassword"
                        class="block text-sm font-medium text-gray-700 mb-1"
                        >Konfirmasi Password</label
                    >
                    <input
                        type="password"
                        name="confirmPassword"
                        id="confirmPassword"
                        required
                        class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                        placeholder="••••••••"
                    />
                </div>

                <button
                    type="submit"
                    class="w-full bg-primary text-white font-bold py-3 px-4 rounded-lg hover:bg-orange-600 transition-colors shadow-lg shadow-orange-200 mt-2"
                >
                    Daftar
                </button>
            </form>

            <div class="mt-8 text-center text-sm text-gray-500">
                Sudah punya akun?
                <a href="/login" class="text-primary font-bold hover:underline"
                    >Masuk di sini</a
                >
            </div>
        </div>
    </div>
</Layout>
