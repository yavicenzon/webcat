---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import ProductCard from "../components/ProductCard";
import { products } from "../data/products";
import {
	ShoppingCart,
	ArrowRight,
	PawPrint,
	Sparkles,
	ChevronDown,
	Zap,
} from "lucide-react";

// Hero Images
const heroImage = "/visuals/3.jpeg";
---

<Layout title="Cat Market - Belanja Kebutuhan Anabul">
	<Navbar client:load />

	<main
		class="min-h-screen pt-[120px] md:pt-[140px] bg-white pb-20 overflow-hidden"
	>
		<div class="container mx-auto px-4">
			{/* New Hero Section */}
			<div
				class="flex flex-col-reverse md:flex-row items-center gap-8 md:gap-16 mb-20 relative"
			>
				{/* Left: Image (Hero) */}
				<div class="w-full md:w-1/2 relative md:-ml-8 lg:-ml-12">
					<div
						class="relative z-10 md:rounded-r-[2.5rem] rounded-[2.5rem] overflow-hidden shadow-2xl transform rotate-1 hover:rotate-0 transition-all duration-700 group"
					>
						<img
							src={heroImage}
							alt="Cat Market Hero"
							class="w-full h-[300px] md:h-[450px] object-cover object-center group-hover:scale-105 transition-transform duration-700"
						/>
						{/* Overlay highlight */}
						<div
							class="absolute inset-0 bg-gradient-to-tr from-orange-500/20 to-transparent pointer-events-none"
						>
						</div>
					</div>

					{/* Decorative Elements behind image */}
					<div
						class="absolute -top-4 -left-4 w-full h-full md:rounded-r-[2.5rem] rounded-[2.5rem] border-2 border-primary/30 z-0 -rotate-2 hidden md:block"
					>
					</div>
					<div
						class="absolute -bottom-12 -right-12 w-48 h-48 bg-yellow-300 rounded-full blur-3xl opacity-40 z-0 animate-pulse"
					>
					</div>
					<div
						class="absolute top-12 -left-12 w-40 h-40 bg-orange-400 rounded-full blur-3xl opacity-30 z-0"
					>
					</div>

					{/* Floating Badge */}
					<div
						class="absolute bottom-12 right-12 z-20 bg-white/90 backdrop-blur-sm p-4 rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] flex items-center gap-4 animate-[bounce_3s_infinite]"
					>
						<div
							class="bg-gradient-to-br from-orange-400 to-red-500 p-3 rounded-full shadow-lg shadow-orange-200"
						>
							<PawPrint className="w-6 h-6 text-white" />
						</div>
						<div>
							<p
								class="text-xs text-gray-500 font-bold uppercase tracking-wide"
							>
								Terpercaya
							</p>
							<p class="text-sm font-black text-gray-800">
								10k+ Cat Lovers
							</p>
						</div>
					</div>
				</div>

				{/* Right: Content */}
				<div
					class="w-full md:w-1/2 md:pl-8 lg:pl-12 pt-8 md:pt-0 relative z-10"
				>
					<div
						class="inline-flex items-center gap-2 px-4 py-2 bg-orange-50 text-orange-600 rounded-full text-sm font-bold mb-6 border border-orange-100 shadow-sm"
					>
						<Sparkles className="w-4 h-4 fill-orange-400" />
						<span>Surga Belanja Kebutuhan Anabul</span>
					</div>

					<h1
						class="text-4xl md:text-6xl font-black text-gray-900 leading-[1.1] mb-8 tracking-tight"
					>
						Manjakan <br />
						<span
							class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 via-red-500 to-pink-500 relative inline-block"
						>
							Anabul
							<svg
								class="absolute w-full h-3 -bottom-2 left-0 text-yellow-300 opacity-60"
								viewBox="0 0 100 10"
								preserveAspectRatio="none"
							>
								<path
									d="M0 5 Q 50 10 100 5"
									stroke="currentColor"
									stroke-width="8"
									fill="none"
									stroke-linecap="round"></path>
							</svg>
						</span>
						<br />
						Kesayangan!
					</h1>

					<p
						class="text-lg text-gray-600 mb-10 leading-relaxed max-w-lg"
					>
						Temukan makanan premium, mainan interaktif, dan aksesori
						lucu untuk kebahagiaan kucingmu.
						<span class="block mt-2 font-bold text-gray-800"
							>Kualitas terbaik, harga bersahabat! 😻</span
						>
					</p>

					<div class="flex flex-col sm:flex-row gap-5">
						<a
							href="/market"
							class="group bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold py-3 px-8 rounded-full shadow-lg shadow-orange-200 transform hover:-translate-y-1 hover:shadow-xl transition-all flex items-center justify-center gap-3 text-base"
						>
							<ShoppingCart
								className="w-5 h-5 group-hover:animate-[wiggle_0.5s_ease-in-out_infinite]"
							/>
							Belanja Sekarang
						</a>
						<a
							href="#featured"
							class="group bg-white text-gray-700 border-2 border-gray-100 font-bold py-3 px-8 rounded-full hover:bg-gray-50 hover:border-orange-200 hover:text-orange-600 transition-all flex items-center justify-center gap-2 text-base"
						>
							Lihat Promo <ArrowRight
								className="w-4 h-4 group-hover:translate-x-1 transition-transform"
							/>
						</a>
					</div>
				</div>
			</div>

			{/* Categories (Quick Access) */}
			<div class="mb-24">
				<h3
					class="text-center text-gray-400 font-bold mb-8 uppercase tracking-widest text-xs"
				>
					Kategori Pilihan
				</h3>
				<div class="flex flex-wrap justify-center gap-3 md:gap-4">
					{
						[
							{
								name: "Makanan Kucing",
								color: "bg-red-50 text-red-600 border-red-100 hover:bg-red-100",
							},
							{
								name: "Mainan",
								color: "bg-blue-50 text-blue-600 border-blue-100 hover:bg-blue-100",
							},
							{
								name: "Kandang",
								color: "bg-green-50 text-green-600 border-green-100 hover:bg-green-100",
							},
							{
								name: "Pasir",
								color: "bg-yellow-50 text-yellow-600 border-yellow-100 hover:bg-yellow-100",
							},
							{
								name: "Vitamin",
								color: "bg-purple-50 text-purple-600 border-purple-100 hover:bg-purple-100",
							},
							{
								name: "Aksesori",
								color: "bg-pink-50 text-pink-600 border-pink-100 hover:bg-pink-100",
							},
							{
								name: "Baju",
								color: "bg-indigo-50 text-indigo-600 border-indigo-100 hover:bg-indigo-100",
							},
						].map((cat, idx) => (
							<a
								href={`/market?category=${cat.name}`}
								class={`px-6 py-3 rounded-full border transition-all font-bold text-sm transform hover:-translate-y-1 hover:shadow-md ${cat.color}`}
							>
								{cat.name}
							</a>
						))
					}
				</div>
			</div>

			{/* Flash Sale / Featured */}
			<div
				id="featured"
				className="mb-20 p-6 md:p-10 bg-gradient-to-br from-white to-red-50 rounded-[2.5rem] shadow-xl border border-red-100 relative overflow-hidden group"
			>
				<div
					className="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-orange-400 via-red-500 to-purple-500"
				>
				</div>
				<div
					className="absolute top-0 right-0 w-96 h-96 bg-orange-200 rounded-full blur-[100px] opacity-20 -mr-24 -mt-24 pointer-events-none"
				>
				</div>

				<div
					className="relative z-10 flex flex-col md:flex-row items-center justify-between mb-10 gap-6"
				>
					<div>
						<div className="flex items-center gap-3 mb-2">
							<span
								className="flex items-center gap-2 bg-red-600 text-white px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest animate-pulse shadow-red-200 shadow-md"
							>
								<Zap className="w-3 h-3 fill-white" /> Flash Sale
							</span>
						</div>
						<h2
							className="text-2xl md:text-4xl font-black text-gray-900 leading-tight"
						>
							Waktu Terbatas! <span class="text-red-500"
								>Diskon 70%</span
							>
						</h2>
					</div>

					{/* Countdown Timer - Capsule Shape (Horizontal) */}
					<div
						id="countdown"
						className="flex items-center gap-6 bg-gray-900 text-white px-8 py-3 rounded-full shadow-lg border-2 border-gray-800"
					>
						{/* Hours */}
						<div class="text-center min-w-[30px]">
							<span
								id="hours"
								class="block text-2xl font-bold leading-none font-mono text-white"
								>02</span
							>
							<span
								class="text-[9px] text-gray-400 font-bold uppercase tracking-wider mt-1 block"
								>Jam</span
							>
						</div>

						<span class="text-xl font-bold text-gray-600 -mt-3"
							>:</span
						>

						{/* Minutes */}
						<div class="text-center min-w-[30px]">
							<span
								id="minutes"
								class="block text-2xl font-bold leading-none font-mono text-white"
								>45</span
							>
							<span
								class="text-[9px] text-gray-400 font-bold uppercase tracking-wider mt-1 block"
								>Mnt</span
							>
						</div>

						<span class="text-xl font-bold text-gray-600 -mt-3"
							>:</span
						>

						{/* Seconds */}
						<div class="text-center min-w-[30px]">
							<span
								id="seconds"
								class="block text-2xl font-bold leading-none text-red-500 font-mono"
								>12</span
							>
							<span
								class="text-[9px] text-gray-400 font-bold uppercase tracking-wider mt-1 block"
								>Dtk</span
							>
						</div>
					</div>
				</div>

				{/* Product Grid - Fixed sizing */}
				<div
					className="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 sm:gap-6"
				>
					{
						products
							.filter((p) => p.discount)
							.slice(0, 6)
							.map((product) => (
								<div
									key={product.id}
									className="w-full max-w-[200px] mx-auto"
								>
									<ProductCard client:visible {...product} />
								</div>
							))
					}
				</div>
			</div>

			{/* Main Product Grid */}
			<section>
				<div
					className="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6"
				>
					<h2
						className="text-3xl md:text-4xl font-black text-gray-900 flex items-center gap-3"
					>
						<span
							class="w-3 h-8 bg-gradient-to-b from-orange-400 to-red-500 rounded-full shadow-lg shadow-orange-200"
						></span>
						Rekomendasi Pilihan
					</h2>
					<div className="flex p-1.5 bg-gray-100 rounded-2xl w-fit">
						<button
							class="px-6 py-2.5 bg-white text-gray-900 text-sm rounded-xl font-bold shadow-sm transition-all"
							>Terkait</button
						>
						<button
							class="px-6 py-2.5 text-gray-500 text-sm rounded-xl hover:bg-gray-200 font-semibold transition-all"
							>Terbaru</button
						>
						<button
							class="px-6 py-2.5 text-gray-500 text-sm rounded-xl hover:bg-gray-200 font-semibold transition-all"
							>Terlaris</button
						>
					</div>
				</div>

				<div
					class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 sm:gap-6"
				>
					{
						products.map((product) => (
							<div
								key={product.id}
								className="h-full w-full max-w-[220px] mx-auto"
							>
								<ProductCard client:visible {...product} />
							</div>
						))
					}
				</div>

				<div className="mt-20 text-center">
					<button
						className="group bg-white border-2 border-gray-100 hover:border-primary hover:text-primary text-gray-600 font-bold py-4 px-12 rounded-full transition-all flex items-center gap-3 mx-auto shadow-sm hover:shadow-md"
					>
						Muat Lebih Banyak <ChevronDown
							className="w-5 h-5 group-hover:translate-y-1 transition-transform"
						/>
					</button>
				</div>
			</section>
		</div>
	</main>
</Layout>

<script>
	// Countdown Timer Logic
	const countdown = () => {
		const countDate = new Date().getTime() + 1000 * 60 * 60 * 4; // 4 hours from now

		const updateTimer = () => {
			const now = new Date().getTime();
			const gap = countDate - now;

			if (gap < 0) return; // Stop if time passed

			const second = 1000;
			const minute = second * 60;
			const hour = minute * 60;

			const h = Math.floor(gap / hour);
			const m = Math.floor((gap % hour) / minute);
			const s = Math.floor((gap % minute) / second);

			const hEl = document.getElementById("hours");
			const mEl = document.getElementById("minutes");
			const sEl = document.getElementById("seconds");

			if (hEl) hEl.innerText = h < 10 ? "0" + h : h.toString();
			if (mEl) mEl.innerText = m < 10 ? "0" + m : m.toString();
			if (sEl) sEl.innerText = s < 10 ? "0" + s : s.toString();
		};

		setInterval(updateTimer, 1000);
		updateTimer(); // Initial call
	};

	// Run on load and after navigation (for View Transitions)
	document.addEventListener("astro:page-load", countdown);
	countdown(); // Fallback for initial load if not using view transitions
</script>

<style>
	@keyframes wiggle {
		0%,
		100% {
			transform: rotate(0deg);
		}
		25% {
			transform: rotate(-10deg);
		}
		75% {
			transform: rotate(10deg);
		}
	}
</style>
